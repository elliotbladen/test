# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Odds API (swap scraper after 500 visitors)
NEXT_PUBLIC_ODDS_API_KEY=your-odds-api-key

# Scraper target - oddscomparison | oddsapi
ODDS_SCRAPER_TARGET=oddscomparison

# Optional override. Leave blank to use the built-in Fox Sports attack/kicking/defence URLs.
NRL_STYLE_STATS_URL=

# Monday after Round 1. Used to infer the completed round for weekly Monday scrapes.
NRL_ROUND_ONE_MONDAY=2026-03-02
